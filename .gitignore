# Not sure what a .gitignore is?
# See: https://git-scm.com/docs/gitignore

# These are directly copied from Jekyll's first-party docs on `.gitignore` files:
# https://jekyllrb.com/tutorials/using-jekyll-with-bundler/#commit-to-source-control

# Ignore the default location of the built site, and caches and metadata generated by Jekyll
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore folders generated by Bundler
.bundle/
vendor/

# Ignore colcon build artefacts but keep workspace/src tracked (with .gitkeep)
workspace/build/
workspace/install/
workspace/log/
workspace/src/*
!workspace/src/.gitkeep

# Core stack is cloned in by each user; never commit it or its build output
core_ws/build/
core_ws/install/
core_ws/log/
core_ws/src/*
!core_ws/src/.gitkeep

# Ignore the history file itself, but keep the mount-point directory
.zsh_history_dir/.zsh_history
