# --- Powerlevel10k instant prompt (must stay near the top) ---
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
HYPHEN_INSENSITIVE="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
zstyle ':omz:update' mode disabled

plugins=(
  zsh-autosuggestions
  zsh-completions
  fzf-tab
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# --- Powerlevel10k config (baked in, no wizard needed) ---
[[ -r ~/.p10k.zsh ]] && source ~/.p10k.zsh

# --- ROS 2 Environment ---
source /opt/ros/${ROS_DISTRO}/setup.zsh

# --- Workspace Overlay (auto-source if built) ---
if [ -f /workspace/install/setup.zsh ]; then
  source /workspace/install/setup.zsh
fi

# --- Zsh History Settings ---
export HISTFILE=/root/.zsh_history_dir/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000
setopt appendhistory
setopt sharehistory
setopt incappendhistory

# Add any of your favorite aliases here!
alias ll='ls -la'
