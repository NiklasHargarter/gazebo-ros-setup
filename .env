ROS_DISTRO=humble

# Default overlay set for raw `docker compose ...`. Drop the nvidia file if you
# don't have an NVIDIA GPU + container toolkit.
COMPOSE_FILE=docker-compose.yml:docker-compose.nvidia.yml

# ros-shortcuts.sh picks overlays via ROS_PROFILE instead. Set to nvidia to
# match the COMPOSE_FILE default above.
# ROS_PROFILE=nvidia
