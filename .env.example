ROS_DISTRO=humble

# Image used by docker-compose.yml at runtime. Must be a locally-built
# consumer image whose Dockerfile does FROM project-core:${ROS_DISTRO}.
# See consumer-template/ for a starting point.
CONSUMER_IMAGE=my-consumer:humble

# Server-client setup (see docs/server-client.md)
# WORKSTATION_IP=
# ROS_PROFILE=nvidia
